# --- API environment ---

# Server
PORT=3000
# Comma-separated list of allowed browser origins (CORS + Socket.io)
WEB_ORIGIN=http://localhost:4200

# PostgreSQL (GCP Cloud SQL)
DATABASE_URL=postgresql://user:password@localhost:5432/investment_tracker?schema=public

# Redis (GCP Memorystore)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Market data providers (set one)
FINNHUB_API_KEY=
COINGECKO_API_KEY=
