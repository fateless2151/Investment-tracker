generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String?
  portfolios   Portfolio[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Portfolio {
  id            String        @id @default(uuid())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  name          String
  baseCurrency  String        @default("USD")
  positions     Position[]
  transactions  Transaction[]
  cashBalances  CashBalance[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
}

model CashBalance {
  id          String    @id @default(uuid())
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId String
  currency    String
  amount      Decimal   @default(0) @db.Decimal(24, 8)
  updatedAt   DateTime  @updatedAt

  @@unique([portfolioId, currency])
  @@index([portfolioId])
}

model Position {
  id           String        @id @default(uuid())
  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId  String
  symbol       String
  assetType    AssetType     @default(STOCK)
  quantity     Decimal       @db.Decimal(24, 8)
  avgCostBasis Decimal       @db.Decimal(24, 8)
  currency     String        @default("USD")
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([portfolioId, symbol])
  @@index([portfolioId])
}

model Transaction {
  id          String          @id @default(uuid())
  portfolio   Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId String
  position    Position?       @relation(fields: [positionId], references: [id], onDelete: SetNull)
  positionId  String?
  type        TransactionType
  symbol      String
  quantity    Decimal         @db.Decimal(24, 8)
  price       Decimal         @db.Decimal(24, 8)
  fees        Decimal         @default(0) @db.Decimal(24, 8)
  // Realized gain/loss booked on SELL (proceeds - avg-cost basis, net of fees).
  // Null for non-sell transactions.
  realizedPnl Decimal?        @db.Decimal(24, 8)
  currency    String          @default("USD")
  executedAt  DateTime
  createdAt   DateTime        @default(now())

  @@index([portfolioId])
  @@index([positionId])
}

enum AssetType {
  STOCK
  CRYPTO
  ETF
  CASH
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  DEPOSIT
  WITHDRAWAL
}
